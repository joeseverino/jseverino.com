---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import PrivateTooltip from '@components/PrivateTooltip.astro';
import { getPage } from '@lib/content';

const page = await getPage('resume');
const usesPrivateLinks = page.bodyHtml.includes('data-private-tooltip');
---

<BaseLayout
  seo={{
    title: page.title,
    description: page.description,
    path: page.path,
    pageType: 'profile',
    breadcrumbs: [
      { name: 'Home', url: '/' },
      { name: page.title, url: page.path },
    ],
  }}
>
  <main id="main" class="content-page resume-page">
    <div class="content-flow">
      <PageHero title={page.title} />
      <div class="prose" set:html={page.bodyHtml} />
    </div>
  </main>
  {usesPrivateLinks && <PrivateTooltip />}
</BaseLayout>
