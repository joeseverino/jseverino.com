---
import BaseLayout from '@layouts/BaseLayout.astro';
import Picture from '@components/Picture.astro';
import PrivateTooltip from '@components/PrivateTooltip.astro';
import { formatDate, getWriteups, titleCase } from '@lib/content';

export async function getStaticPaths() {
  return (await getWriteups()).map((writeup) => ({
    params: { slug: writeup.slug },
    props: { writeup },
  }));
}

const { writeup } = Astro.props;
const usesPrivateLinks = writeup.bodyHtml.includes('data-private-tooltip');
---

<BaseLayout
  seo={{
    title: writeup.title,
    description: writeup.description,
    path: `/portfolio/${writeup.slug}/`,
    image: writeup.heroImage,
    type: 'article',
    publishedTime: writeup.date,
    modifiedTime: writeup.lastReviewed,
    tags: writeup.technologies,
    breadcrumbs: [
      { name: 'Home', url: '/' },
      { name: 'Portfolio', url: '/portfolio/' },
      { name: writeup.title, url: `/portfolio/${writeup.slug}/` },
    ],
  }}
>
  <main id="main" class="article">
    <header class="article-header">
      <div class="article-meta">
        <h1 class="article-title">{writeup.title}</h1>
        <p class="article-date"><time datetime={writeup.date}>{formatDate(writeup.date)}</time></p>
      </div>
      <figure class="article-hero">
        <Picture
          src={writeup.heroImage}
          alt={writeup.heroAlt}
          sizes="(max-width: 720px) 100vw, 672px"
          loading="eager"
          fetchpriority="high"
        />
      </figure>
    </header>

    <article class="prose" set:html={writeup.bodyHtml} />

    {
      writeup.technologies.length > 0 && (
        <footer class="article-tags">
          <h3>Technologies Used</h3>
          <div class="tech-pills">
            {writeup.technologies.map((tag: string) => (
              <a href={`/tag/${tag}/`} rel="tag">{titleCase(tag)}</a>
            ))}
          </div>
          <hr class="article-separator" />
        </footer>
      )
    }
  </main>
  {usesPrivateLinks && <PrivateTooltip />}
</BaseLayout>
