---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/PageHero.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getAllTags, getWriteups, titleCase } from '@lib/content';

export async function getStaticPaths() {
  return (await getAllTags()).map((tag) => ({
    params: { slug: tag.slug },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const allWriteups = await getWriteups();
const writeups = allWriteups.filter((writeup) => writeup.technologies.includes(tag.slug));
const tagName = titleCase(tag.slug);
const projectLabel = writeups.length === 1 ? 'project' : 'projects';
---

<BaseLayout
  seo={{
    title: `${tagName} Projects`,
    description: `Portfolio writeups tagged ${tagName}.`,
    path: `/tag/${tag.slug}/`,
    pageType: 'itemList',
    itemListItems: writeups.map((writeup) => ({
      name: writeup.title,
      url: `/portfolio/${writeup.slug}/`,
    })),
    breadcrumbs: [
      { name: 'Home', url: '/' },
      { name: 'Portfolio', url: '/portfolio/' },
      { name: tagName, url: `/tag/${tag.slug}/` },
    ],
  }}
>
  <main id="main" class="wide section">
    <PageHero
      class="page-hero--tag"
      title={`${tagName} Projects`}
      description={`${writeups.length} ${projectLabel} tagged ${tagName}.`}
    >
      <nav class="page-actions" aria-label="Portfolio navigation">
        <a href="/portfolio/">All projects</a>
      </nav>
    </PageHero>
    <hr class="page-divider" />
    <ul class="project-grid">
      {writeups.map((writeup, index) => <ProjectCard writeup={writeup} eager={index === 0} />)}
    </ul>
  </main>
</BaseLayout>
