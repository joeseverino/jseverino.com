---
type SocialLink = { label: string; href: string };

type Props = {
  links: SocialLink[];
  class?: string;
};

const SUPPORTED = new Set(['LinkedIn', 'GitHub']);

const { links, class: className } = Astro.props;
const supported = links.filter((link) => {
  if (SUPPORTED.has(link.label)) return true;
  console.warn(`Skipping unsupported social icon label: ${link.label}`);
  return false;
});
const classes = ['social-links', className].filter(Boolean).join(' ');
---

<ul class={classes}>
  {supported.map((link) => (
    <li>
      <a href={link.href} aria-label={link.label} rel="me">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <use href={`#icon-${link.label.toLowerCase()}`}></use>
        </svg>
      </a>
    </li>
  ))}
</ul>
