---
import { site } from '@lib/site';
import { getSiteChrome } from '@lib/content';

type Breadcrumb = { name: string; url: string };

type Props = {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  breadcrumbs?: Breadcrumb[];
};

const {
  title = site.defaultTitle,
  description = site.defaultDescription,
  path = Astro.url.pathname,
  image = site.defaultOgImage,
  type = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
  tags = [],
  breadcrumbs = [],
} = Astro.props;

const {
  name: personName,
  title: jobTitle,
  summary: personSummary,
  skills: personSkills,
  socialLinks: personSocialLinks,
} = getSiteChrome();

const canonical = new URL(path, site.url).href;
const ogImage = new URL(image, site.url).href;
const fullTitle = title === site.defaultTitle ? title : `${title} | ${personName}`;

const person = {
  '@type': 'Person',
  '@id': `${site.url}/#person`,
  name: personName,
  url: site.url,
  jobTitle,
  description: personSummary || site.defaultDescription,
  knowsAbout: personSkills,
  sameAs: personSocialLinks.map((link) => link.href),
};

const breadcrumbList =
  breadcrumbs.length > 0
    ? {
        '@type': 'BreadcrumbList',
        '@id': `${canonical}#breadcrumb`,
        itemListElement: breadcrumbs.map((bc, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: bc.name,
          item: new URL(bc.url, site.url).href,
        })),
      }
    : undefined;

type JsonLdNode = Record<string, unknown>;
type JsonLd = {
  '@context': 'https://schema.org';
  '@graph': JsonLdNode[];
};

const graph: JsonLdNode[] = [
  type === 'article'
    ? {
        '@type': 'Article',
        '@id': `${canonical}#article`,
        headline: title,
        description,
        url: canonical,
        image: ogImage,
        datePublished: publishedTime,
        dateModified: modifiedTime || publishedTime,
        keywords: tags,
        author: { '@id': `${site.url}/#person` },
        publisher: { '@id': `${site.url}/#person` },
        mainEntityOfPage: { '@id': canonical },
      }
    : {
        '@type': 'WebSite',
        '@id': `${site.url}/#website`,
        name: site.name,
        url: site.url,
        publisher: { '@id': `${site.url}/#person` },
      },
  person,
];

if (breadcrumbList) graph.push(breadcrumbList);

const jsonLd: JsonLd = {
  '@context': 'https://schema.org',
  '@graph': graph,
};
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={canonical} />
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{tags.map((tag) => <meta property="article:tag" content={tag} />)}
<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />
