---
import { site } from '@lib/site';
import { getImageDimensions } from '@lib/images';

type Breadcrumb = { name: string; url: string };
type ListItem = { name: string; url: string };

type Props = {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  breadcrumbs?: Breadcrumb[];
  pageType?: 'profile' | 'collection' | 'itemList';
  itemListItems?: ListItem[];
};

const {
  title = site.defaultTitle,
  description = site.defaultDescription,
  path = Astro.url.pathname,
  image = site.defaultOgImage,
  type = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
  tags = [],
  breadcrumbs = [],
  pageType,
  itemListItems = [],
} = Astro.props;

const canonical = new URL(path, site.url).href;
const ogImage = new URL(image, site.url).href;
const personImage = new URL('/assets/brand/joe-severino.jpg', site.url).href;
const ogDimensions =
  getImageDimensions(image) ??
  (image === site.defaultOgImage
    ? { width: site.defaultOgImageWidth, height: site.defaultOgImageHeight }
    : undefined);
const fullTitle = title === site.defaultTitle ? title : `${title} | ${site.name}`;

const imageObject: Record<string, unknown> = {
  '@type': 'ImageObject',
  url: ogImage,
  ...(ogDimensions ? { width: ogDimensions.width, height: ogDimensions.height } : {}),
};

const person = {
  '@type': 'Person',
  '@id': `${site.url}/#person`,
  name: site.name,
  url: site.url,
  image: personImage,
  jobTitle: site.jobTitle,
  description: site.summary,
  knowsAbout: site.skills,
  sameAs: site.socialLinks.map((link) => link.href),
};

const breadcrumbList =
  breadcrumbs.length > 0
    ? {
        '@type': 'BreadcrumbList',
        '@id': `${canonical}#breadcrumb`,
        itemListElement: breadcrumbs.map((bc, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: bc.name,
          item: new URL(bc.url, site.url).href,
        })),
      }
    : undefined;

type JsonLdNode = Record<string, unknown>;
type JsonLd = {
  '@context': 'https://schema.org';
  '@graph': JsonLdNode[];
};

const primaryNode: JsonLdNode =
  type === 'article'
    ? {
        '@type': 'Article',
        '@id': `${canonical}#article`,
        headline: title,
        description,
        url: canonical,
        image: imageObject,
        datePublished: publishedTime,
        dateModified: modifiedTime || publishedTime,
        keywords: tags,
        author: { '@id': `${site.url}/#person` },
        publisher: { '@id': `${site.url}/#person` },
        mainEntityOfPage: { '@id': canonical },
      }
    : {
        '@type': 'WebSite',
        '@id': `${site.url}/#website`,
        name: site.name,
        url: site.url,
        publisher: { '@id': `${site.url}/#person` },
      };

const graph: JsonLdNode[] = [primaryNode, person];

if (breadcrumbList) graph.push(breadcrumbList);

if (pageType === 'profile') {
  graph.push({
    '@type': 'ProfilePage',
    '@id': `${canonical}#profilepage`,
    url: canonical,
    name: fullTitle,
    description,
    mainEntity: { '@id': `${site.url}/#person` },
  });
} else if (pageType === 'collection') {
  graph.push({
    '@type': 'CollectionPage',
    '@id': `${canonical}#collectionpage`,
    url: canonical,
    name: fullTitle,
    description,
    isPartOf: { '@id': `${site.url}/#website` },
    about: { '@id': `${site.url}/#person` },
  });
} else if (pageType === 'itemList') {
  graph.push({
    '@type': 'ItemList',
    '@id': `${canonical}#itemlist`,
    url: canonical,
    name: title,
    numberOfItems: itemListItems.length,
    itemListElement: itemListItems.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.name,
      url: new URL(item.url, site.url).href,
    })),
  });
}

const jsonLd: JsonLd = {
  '@context': 'https://schema.org',
  '@graph': graph,
};
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={canonical} />
<meta property="og:type" content={type} />
<meta property="og:site_name" content={site.name} />
<meta property="og:locale" content="en_US" />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
{ogDimensions && <meta property="og:image:width" content={String(ogDimensions.width)} />}
{ogDimensions && <meta property="og:image:height" content={String(ogDimensions.height)} />}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{tags.map((tag) => <meta property="article:tag" content={tag} />)}
<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/</g, '\\u003c')} />
