---
import { getSiteChrome } from '@lib/content';
import NavLinks from '@components/NavLinks.astro';

const current = Astro.url.pathname;
const normalize = (p: string) => p.replace(/\/$/, '') || '/';
const { name, navItems } = await getSiteChrome();
const navigation = navItems.map((item) => ({
  ...item,
  current: normalize(current) === normalize(item.href),
}));
---

<div id="scroll-sentinel" class="scroll-sentinel"></div>
<header class="site-header" data-sticky-header>
  <script is:inline>
    // Set header height variable as early as possible to prevent layout shifts.
    // We only set it if the height is > 0 to avoid race conditions during parsing.
    const syncHeight = () => {
      const h = document.querySelector('[data-sticky-header]');
      if (h && h.offsetHeight > 0) {
        document.documentElement.style.setProperty('--header-height', `${h.offsetHeight}px`);
      }
    };

    syncHeight();
    window.addEventListener('resize', syncHeight, { passive: true });
    // Also sync on DOMContentLoaded to ensure we have the final layout height
    document.addEventListener('DOMContentLoaded', syncHeight);

    // Use IntersectionObserver for high-performance scroll state detection
    const header = document.querySelector('[data-sticky-header]');
    const sentinel = document.querySelector('#scroll-sentinel');
    if (header && sentinel) {
      const observer = new IntersectionObserver((entries) => {
        // Sentinel is at the very top. When it's not intersecting, we have scrolled.
        header.classList.toggle('scrolled', !entries[0].isIntersecting);
      }, { threshold: 0 });
      observer.observe(sentinel);
    }
  </script>
  <div class="wide site-nav">
    <a class="brand" href="/" rel="home" aria-current={current === '/' ? 'page' : undefined}>{name}</a>

    <nav class="primary-nav" aria-label="Primary navigation">
      <NavLinks items={navigation} listClass="nav-list" linkClass="nav-link" />
    </nav>

    <button
      class="nav-toggle"
      type="button"
      aria-controls="mobile-nav"
      aria-expanded="false"
      aria-label="Open menu"
      data-nav-toggle
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobile-nav" data-mobile-nav hidden>
    <nav class="mobile-nav-panel" aria-label="Mobile navigation">
      <button
        class="visually-hidden"
        type="button"
        aria-label="Close menu"
        data-nav-close
      ></button>
      <NavLinks
        items={navigation}
        listClass="mobile-nav-list"
        linkClass="mobile-nav-link"
        linkDataAttribute="data-mobile-nav-link"
      />
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-sticky-header]');

  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const mobileNav = document.querySelector<HTMLElement>('[data-mobile-nav]');
  const closers = document.querySelectorAll<HTMLElement>('[data-nav-close]');
  const mobileNavLinkSelector = '[data-mobile-nav-link]';

  if (toggle && mobileNav) {
    document.body.classList.add('nav-js-ready');
    const mobileNavItems = mobileNav.querySelectorAll<HTMLElement>('.mobile-nav-list li');
    let lastClosed = 0;

    const createBackdrop = () => {
      if (document.getElementById('mobile-menu-backdrop')) return;
      const backdrop = document.createElement('div');
      backdrop.id = 'mobile-menu-backdrop';
      document.body.appendChild(backdrop);
    };

    const removeBackdrop = () => {
      document.getElementById('mobile-menu-backdrop')?.remove();
    };

    const setItemDelays = () => {
      mobileNavItems.forEach((item, index) => {
        item.style.transitionDelay = `${index * 0.055}s`;
      });
    };

    const clearItemDelays = () => {
      mobileNavItems.forEach((item) => {
        item.style.transitionDelay = '0s';
      });
    };

    const open = () => {
      if (Date.now() - lastClosed < 350) return;
      // Re-sync height right before opening to ensure no overlap
      const h = document.querySelector<HTMLElement>('[data-sticky-header]');
      if (h && h.offsetHeight > 0) {
        document.documentElement.style.setProperty('--header-height', `${h.offsetHeight}px`);
      }
      mobileNav.hidden = false;
      createBackdrop();
      setItemDelays();
      requestAnimationFrame(() => {
        mobileNav.classList.add('is-open');
        requestAnimationFrame(() => mobileNav.classList.add('nav-items-ready'));
      });
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close menu');
      const firstLink = mobileNav.querySelector<HTMLAnchorElement>(mobileNavLinkSelector);
      firstLink?.focus();
    };
    const close = () => {
      lastClosed = Date.now();
      mobileNav.classList.remove('nav-items-ready');
      mobileNav.classList.remove('is-open');
      removeBackdrop();
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
      const onEnd = (event: TransitionEvent) => {
        if (event.target !== mobileNav) return;
        mobileNav.hidden = true;
        clearItemDelays();
        mobileNav.removeEventListener('transitionend', onEnd);
      };
      mobileNav.addEventListener('transitionend', onEnd);
      toggle.focus();
    };

    toggle.addEventListener('click', () => {
      if (mobileNav.classList.contains('is-open')) close();
      else open();
    });
    closers.forEach((el) => el.addEventListener('click', close));
    mobileNav.querySelectorAll(mobileNavLinkSelector).forEach((el) => {
      el.addEventListener('click', close);
    });
    mobileNav.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      if (target.closest(mobileNavLinkSelector) || target.closest('[data-nav-close]')) return;
      close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mobileNav.classList.contains('is-open')) close();
    });
  }
</script>
