---
import { getSiteChrome } from '@lib/content';

const current = Astro.url.pathname;
const { name, navItems } = getSiteChrome();
---

<header class="site-header" data-sticky-header>
  <div class="wide site-nav">
    <a class="brand" href="/" rel="home" aria-current={current === '/' ? 'page' : undefined}>{name}</a>

    <nav class="primary-nav" aria-label="Primary navigation">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li><a class="nav-link" href={item.href} aria-current={current === item.href ? 'page' : undefined}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <button
      class="nav-toggle"
      type="button"
      aria-controls="mobile-nav"
      aria-expanded="false"
      aria-label="Open menu"
      data-nav-toggle
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobile-nav" data-mobile-nav hidden>
    <div class="mobile-nav-backdrop" data-nav-close></div>
    <nav class="mobile-nav-panel" aria-label="Mobile navigation">
      <button
        class="mobile-nav-close"
        type="button"
        aria-label="Close menu"
        data-nav-close
      >
        <span></span>
        <span></span>
      </button>
      <ul class="mobile-nav-list">
        {navItems.map((item) => (
          <li>
            <a
              class="mobile-nav-link"
              href={item.href}
              aria-current={current === item.href ? 'page' : undefined}
            >{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector('[data-sticky-header]');
  if (header) {
    const syncHeaderHeight = () => {
      document.documentElement.style.setProperty('--header-height', `${header.getBoundingClientRect().height}px`);
    };
    const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 4);
    syncHeaderHeight();
    onScroll();
    window.addEventListener('resize', syncHeaderHeight, { passive: true });
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const mobileNav = document.querySelector<HTMLElement>('[data-mobile-nav]');
  const closers = document.querySelectorAll<HTMLElement>('[data-nav-close]');

  if (toggle && mobileNav) {
    document.body.classList.add('nav-js-ready');
    let lastClosed = 0;

    const createBackdrop = () => {
      if (document.getElementById('mobile-menu-backdrop')) return;
      const backdrop = document.createElement('div');
      backdrop.id = 'mobile-menu-backdrop';
      backdrop.addEventListener('click', close);
      document.body.appendChild(backdrop);
    };

    const removeBackdrop = () => {
      document.getElementById('mobile-menu-backdrop')?.remove();
    };

    const setItemDelays = () => {
      mobileNav.querySelectorAll<HTMLElement>('.mobile-nav-list li').forEach((item, index) => {
        item.style.transitionDelay = `${index * 0.055}s`;
      });
    };

    const clearItemDelays = () => {
      mobileNav.querySelectorAll<HTMLElement>('.mobile-nav-list li').forEach((item) => {
        item.style.transitionDelay = '0s';
      });
    };

    const open = () => {
      if (Date.now() - lastClosed < 350) return;
      mobileNav.hidden = false;
      createBackdrop();
      setItemDelays();
      requestAnimationFrame(() => {
        mobileNav.classList.add('is-open');
        requestAnimationFrame(() => mobileNav.classList.add('nav-items-ready'));
      });
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close menu');
      document.body.classList.add('nav-locked');
      const firstLink = mobileNav.querySelector<HTMLAnchorElement>('.mobile-nav-link');
      firstLink?.focus();
    };
    const close = () => {
      lastClosed = Date.now();
      mobileNav.classList.remove('nav-items-ready');
      mobileNav.classList.remove('is-open');
      removeBackdrop();
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
      document.body.classList.remove('nav-locked');
      const onEnd = () => {
        mobileNav.hidden = true;
        clearItemDelays();
        mobileNav.removeEventListener('transitionend', onEnd);
      };
      mobileNav.addEventListener('transitionend', onEnd);
      toggle.focus();
    };

    toggle.addEventListener('click', () => {
      if (mobileNav.classList.contains('is-open')) close();
      else open();
    });
    closers.forEach((el) => el.addEventListener('click', close));
    mobileNav.querySelectorAll('.mobile-nav-link').forEach((el) => {
      el.addEventListener('click', close);
    });
    mobileNav.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      if (target.closest('.mobile-nav-link') || target.closest('.mobile-nav-close')) return;
      close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mobileNav.classList.contains('is-open')) close();
    });
  }
</script>
