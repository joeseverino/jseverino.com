<script>
  // Click handler for `[text](url "private: msg")` anchors in writeup markdown
  // (transformed to `data-private-tooltip` by lib/content.ts). Floats a small
  // status message anchored to the click instead of navigating. Loaded only on
  // pages that render markdown body — bundle is skipped on index/tag/404 pages.
  document.addEventListener('click', (event) => {
    const trigger = (event.target as Element | null)?.closest<HTMLElement>('[data-private-tooltip]');
    if (!trigger) return;
    event.preventDefault();

    document.querySelector('.private-tooltip')?.remove();

    const tip = document.createElement('div');
    tip.className = 'private-tooltip';
    tip.setAttribute('role', 'status');
    tip.textContent = trigger.dataset.privateTooltip ?? '';
    document.body.appendChild(tip);

    const rect = trigger.getBoundingClientRect();
    const margin = 8;
    const maxLeft = document.documentElement.clientWidth - tip.offsetWidth - margin;
    tip.style.top = `${rect.bottom + window.scrollY + margin}px`;
    tip.style.left = `${Math.max(margin, Math.min(rect.left + window.scrollX, maxLeft))}px`;

    requestAnimationFrame(() => tip.setAttribute('data-visible', ''));

    const dismiss = (e: Event) => {
      if (e.type === 'keydown' && (e as KeyboardEvent).key !== 'Escape') return;
      if (e.type === 'click' && tip.contains(e.target as Node)) return;
      tip.remove();
      document.removeEventListener('click', dismiss, true);
      document.removeEventListener('keydown', dismiss);
    };
    setTimeout(() => {
      document.addEventListener('click', dismiss, true);
      document.addEventListener('keydown', dismiss);
    });
  });
</script>
