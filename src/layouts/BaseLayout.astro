---
import SeoHead from '@components/SeoHead.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import '@styles/base.css';

type Props = {
  seo?: Parameters<typeof SeoHead>[0];
  bodyClass?: string;
  /** Extra third-party origins to preconnect to, beyond the site-wide defaults. */
  preconnect?: string[];
};

const { seo = {}, bodyClass, preconnect = [] } = Astro.props;

// `static.cloudflareinsights.com` serves the Cloudflare Web Analytics beacon,
// auto-injected into every HTML response by the Cloudflare proxy. Warming the
// DNS + TLS connection here removes ~100-300ms of cold-start latency for it.
const preconnectOrigins = ['https://static.cloudflareinsights.com', ...preconnect];
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {preconnectOrigins.map((origin) => <link rel="preconnect" href={origin} crossorigin />)}
    <link
      rel="preload"
      href="/assets/fonts/inter/inter-variable-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <SeoHead {...seo} />
    <link rel="icon" href="/assets/icons/favicon-32.png" sizes="32x32" />
    <link rel="icon" href="/assets/icons/favicon-192.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/assets/icons/apple-touch-icon.png" />
  </head>
  <body class={bodyClass || undefined}>
    <a class="skip-link" href="#main">Skip to main content</a>
    <div class="page-shell">
      <Header />
      <slot />
      <Footer />
    </div>
    <script>
      // Any anchor with `data-private-tooltip="..."` opens a small floating
      // message anchored to the click, instead of navigating. Used for links
      // to private services (e.g. tailnet-only).
      document.addEventListener('click', (event) => {
        const trigger = (event.target as Element | null)?.closest<HTMLElement>('[data-private-tooltip]');
        if (!trigger) return;
        event.preventDefault();

        document.querySelector('.private-tooltip')?.remove();

        const tip = document.createElement('div');
        tip.className = 'private-tooltip';
        tip.setAttribute('role', 'status');
        tip.textContent = trigger.dataset.privateTooltip ?? '';
        document.body.appendChild(tip);

        const rect = trigger.getBoundingClientRect();
        const margin = 8;
        const maxLeft = document.documentElement.clientWidth - tip.offsetWidth - margin;
        tip.style.top = `${rect.bottom + window.scrollY + margin}px`;
        tip.style.left = `${Math.max(margin, Math.min(rect.left + window.scrollX, maxLeft))}px`;

        requestAnimationFrame(() => tip.setAttribute('data-visible', ''));

        const dismiss = (e: Event) => {
          if (e.type === 'keydown' && (e as KeyboardEvent).key !== 'Escape') return;
          if (e.type === 'click' && tip.contains(e.target as Node)) return;
          tip.remove();
          document.removeEventListener('click', dismiss, true);
          document.removeEventListener('keydown', dismiss);
        };
        setTimeout(() => {
          document.addEventListener('click', dismiss, true);
          document.addEventListener('keydown', dismiss);
        });
      });
    </script>
  </body>
</html>
