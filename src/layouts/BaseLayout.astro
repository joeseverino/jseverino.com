---
import SeoHead from '@components/SeoHead.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import SocialIconsDefs from '@components/SocialIconsDefs.astro';
import { BRAND } from '@lib/brand.mjs';
import '@styles/base.css';

type Props = {
  seo?: Parameters<typeof SeoHead>[0];
  bodyClass?: string;
  /** Extra third-party origins to preconnect to, beyond the site-wide defaults. */
  preconnect?: string[];
};

const { seo = {}, bodyClass, preconnect = [] } = Astro.props;

// `static.cloudflareinsights.com` serves the Cloudflare Web Analytics beacon,
// auto-injected into every HTML response by the Cloudflare proxy. Warming the
// DNS + TLS connection here removes ~100-300ms of cold-start latency for it.
const preconnectOrigins = ['https://static.cloudflareinsights.com', ...preconnect];
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {preconnectOrigins.map((origin) => <link rel="preconnect" href={origin} crossorigin />)}
    <link
      rel="preload"
      href="/assets/fonts/inter/inter-variable-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="stylesheet" href="/brand.css" />
    <SeoHead {...seo} />
    <link rel="alternate" type="application/rss+xml" title="Joe Severino — Portfolio" href="/feed.xml" />
    <meta name="theme-color" content={BRAND.navy} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/assets/icons/favicon.svg" />
    <link rel="icon" href="/assets/icons/favicon-32.png" sizes="32x32" />
    <link rel="icon" href="/assets/icons/favicon-192.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/assets/icons/apple-touch-icon.png" />
  </head>
  <body class={bodyClass || undefined}>
    <a class="skip-link" href="#main">Skip to main content</a>
    <SocialIconsDefs />
    <div class="page-shell">
      <Header />
      <slot />
      <Footer />
    </div>
  </body>
</html>
