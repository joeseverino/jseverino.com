---
import SeoHead from '@components/SeoHead.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import '@styles/base.css';

type Props = {
  seo?: Parameters<typeof SeoHead>[0];
  bodyClass?: string;
};

const { seo = {}, bodyClass } = Astro.props;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link
      rel="preload"
      href="/assets/fonts/inter/inter-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <SeoHead {...seo} />
    <link rel="icon" href="/assets/media/2025/08/cropped-JS-2-32x32.png" sizes="32x32" />
    <link rel="icon" href="/assets/media/2025/08/cropped-JS-2-192x192.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/assets/media/2025/08/cropped-JS-2-180x180.png" />
  </head>
  <body class={bodyClass || undefined}>
    <div class="page-shell">
      <Header />
      <slot />
      <Footer />
    </div>
  </body>
</html>
