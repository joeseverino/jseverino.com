{
  "name": "jseverino-com",
  "version": "6.0.0",
  "description": "Personal site for Joe Severino — built with Astro, sourced from a private notes vault, served on Cloudflare Pages.",
  "private": true,
  "license": "UNLICENSED",
  "author": "Joe Severino",
  "homepage": "https://jseverino.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joeseverino/jseverino.com.git"
  },
  "type": "module",
  "scripts": {
    "help": "node bin/help.mjs",
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "dev:drafts": "node bin/sync-content.mjs --drafts && ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "sync:content": "node bin/sync-content.mjs",
    "sync:tokens": "node bin/sync-tokens.mjs",
    "snapshot:github": "node bin/snapshot-github.mjs",
    "diagnose": "node bin/diagnose.mjs",
    "diff:build": "node bin/diff-build.mjs",
    "publish:check": "node bin/publish-check.mjs",
    "publish:check:ci": "node bin/ci-rehearsal.mjs",
    "release:check": "node bin/release-check.mjs",
    "deploy:verify": "node bin/deploy-verify.mjs",
    "build": "npm run -s check && npm run -s build:static",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "make:icons": "node bin/make-icons.mjs",
    "make:og": "node bin/make-og-image.mjs",
    "make:social": "node bin/make-github-social.mjs",
    "scaffold:primer": "node bin/scaffold-primer.mjs",
    "scaffold:writeup-field": "node bin/scaffold-writeup-field.mjs",
    "draft:cover-alt": "node bin/draft-cover-alt.mjs",
    "sign:security": "node bin/sign-security.mjs",
    "seo:preview": "node bin/seo-preview.mjs",
    "test:unit": "node --disable-warning=ExperimentalWarning --experimental-strip-types --test 'tests/unit/**/*.test.ts'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:visual": "VISUAL=1 playwright test tests/playwright/visual.spec.ts",
    "test:e2e:visual:update": "VISUAL=1 playwright test tests/playwright/visual.spec.ts --update-snapshots",
    "clean:generated": "node bin/clean-generated.mjs --all",
    "clean:conflicts": "node bin/clean-generated.mjs --conflicts",
    "check": "npm run -s lint:css && npm run -s check:css-vars && NODE_OPTIONS=--max-old-space-size=4096 ASTRO_TELEMETRY_DISABLED=1 astro check --minimumSeverity warning",
    "build:static": "node bin/build-static.mjs",
    "lint:css": "stylelint \"src/styles/**/*.css\"",
    "check:css-vars": "node tests/audits/check-css.mjs",
    "check:security": "node tests/audits/check-security-txt.mjs",
    "check:contrast": "node tests/audits/check-contrast.mjs",
    "check:parity": "node tests/audits/check-vault-mcp-parity.mjs",
    "check:preview": "node tests/audits/check-sitedrift-preview.mjs",
    "check:docs": "node tests/audits/check-docs.mjs",
    "check:types": "tsc -p functions",
    "check:edge": "node tests/audits/check-functions-parity.mjs",
    "check:html": "node tests/audits/check-html.mjs",
    "check:links": "node tests/audits/check-links.mjs",
    "check:weight": "node tests/audits/check-page-weight.mjs",
    "check:seo": "node tests/audits/check-seo.mjs",
    "check:repo-policy": "node tests/audits/check-repository-policy.mjs",
    "audit:assets": "node tests/audits/audit-assets.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.5.1",
    "@types/markdown-it": "^14.1.2",
    "astro": "^6.4.8",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.2.0",
    "markdown-it": "^14.1.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "yaml": "^2.9.0",
    "vite": "^7.3.5",
    "esbuild": "^0.28.1",
    "js-yaml": "^4.2.0"
  },
  "optionalDependencies": {
    "branding-engine": "^0.2.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "playwright": "^1.60.0",
    "sitedrift": "^0.3.11",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
