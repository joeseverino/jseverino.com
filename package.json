{
  "name": "jseverino-com",
  "version": "4.0.0",
  "description": "Personal site for Joe Severino — built with Astro, sourced from a private notes vault, served on Cloudflare Pages.",
  "private": true,
  "license": "UNLICENSED",
  "author": "Joe Severino",
  "homepage": "https://jseverino.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joeseverino/jseverino.com.git"
  },
  "type": "module",
  "scripts": {
    "clean:generated": "node bin/clean-generated.mjs --all",
    "clean:conflicts": "node bin/clean-generated.mjs",
    "sync:content": "node bin/sync-content.mjs",
    "make:og": "node bin/make-og-image.mjs",
    "make:icons": "node bin/make-icons.mjs",
    "make:social": "node bin/make-github-social.mjs",
    "audit:assets": "node bin/audit-assets.mjs",
    "seo:preview": "node bin/seo-preview.mjs",
    "sign:security": "node bin/security-txt.mjs sign",
    "check:security": "node bin/security-txt.mjs check",
    "check:contrast": "node bin/check-contrast.mjs",
    "audit:css": "node bin/audit-css.mjs",
    "lint:css": "stylelint \"src/styles/**/*.css\"",
    "check:parity": "node bin/check-vault-mcp-parity.mjs",
    "scaffold:primer": "node bin/scaffold-primer.mjs",
    "scaffold:writeup-field": "node bin/scaffold-writeup-field.mjs",
    "draft:cover-alt": "node bin/draft-cover-alt.mjs",
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "dev:drafts": "node bin/sync-content.mjs --drafts && ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build:static": "ASTRO_TELEMETRY_DISABLED=1 astro build && sitedrift cloudflare --dir dist --live https://jseverino.com --brand \"Joe Severino\"",
    "build": "npm run -s check && npm run -s build:static",
    "publish:check": "node bin/publish-check.mjs",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "check": "npm run -s lint:css && npm run -s audit:css && NODE_OPTIONS=--max-old-space-size=4096 ASTRO_TELEMETRY_DISABLED=1 astro check --minimumSeverity warning",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:visual": "VISUAL=1 playwright test tests/visual.spec.ts",
    "test:e2e:visual:update": "VISUAL=1 playwright test tests/visual.spec.ts --update-snapshots"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.5.1",
    "@types/markdown-it": "^14.1.2",
    "astro": "^6.4.2",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "yaml": "^2.9.0"
  },
  "optionalDependencies": {
    "branding-engine": "^0.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "playwright": "^1.60.0",
    "sitedrift": "^0.3.6",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
