# Dependencies
# node_modules is a symlink to node_modules.nosync. The `.nosync` suffix
# tells iCloud Drive to never sync that folder — no eviction, no conflict
# copies, no corrupted installs. See docs/Release-Checklist.md for the
# release-time conflict-copy check.
node_modules
node_modules.*
node_modules [0-9]*

# Astro, Vite, and Wrangler generated state
.astro/
.vite/
.wrangler/

# Build output (dist.nosync is the local outDir, dist is Cloudflare's)
/dist*

# Environment and local machine files
.env
.env.*
!.env.example
.dev.vars
.dev.vars.*
!.dev.vars.example
.DS_Store
.claude/
.gemini/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# iCloud Drive conflict copies — this repo lives in iCloud Drive, which
# appends " 2", " 3", etc. to files/dirs it thinks conflict. Never commit them.
* [0-9]
* [0-9].*
