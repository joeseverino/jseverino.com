# Dependencies
# node_modules is a symlink to node_modules.nosync. The `.nosync` suffix
# tells iCloud Drive to never sync that folder — no eviction, no conflict
# copies, no corrupted installs. See README "Working in iCloud Drive".
node_modules
node_modules.*
node_modules [0-9]*

# Astro and Vite generated state
.astro/
.vite/

# Build output (dist.nosync is the local outDir, dist is Cloudflare's)
/dist*

# Environment and local machine files
.env
.env.*
!.env.example
.dev.vars
.dev.vars.*
!.dev.vars.example
.DS_Store
.claude/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
