{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@lib/*": ["./src/lib/*"],
      "@styles/*": ["./src/styles/*"]
    }
  },
  "exclude": [
    "dist",
    "dist.*",
    "functions",
    "node_modules",
    "node_modules.*",
    "node_modules *",
    "node_modules_conflict_tmp",
    "node_modules_conflict*"
  ]
}
