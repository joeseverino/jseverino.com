# Cloudflare Pages headers.
# Order matters: specific rules must come before the catch-all "/*".

# Fingerprinted Astro assets and synced static assets.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=300, must-revalidate

# Security headers for every route.
# The static Content-Security-Policy below is a fallback for static asset
# serving without Pages Functions middleware. In production,
# functions/_middleware.ts replaces this with a per-request nonce-based CSP for
# HTML responses and adds the same nonce to script tags.
#
# The fallback script-src sha256 values cover inline executable scripts emitted
# by the static build:
#   sha256-/rxU... sticky-header / nav script      (Header.astro)
#   sha256-JXxJ... contact form submit script      (ContactForm.astro)
# plus deterministic inline scripts Cloudflare may inject at the edge
# (bot-protection / Speed Brain):
#   sha256-780dS3... Cloudflare edge-injected script #1
#   sha256-W2uumU... Cloudflare edge-injected script #2
# Regenerate the first two after editing those components or upgrading Astro:
#   npm run build:static && npm run csp:hashes
# The production middleware attaches nonces to HTML scripts, so these hashes are
# mainly a fallback and an audit guard. `npm run publish:check` fails if a build
# hash is missing from this file.
# Full detail: vault runbook "Content Security Policy — jseverino.com".
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-/rxUmMybh9carWGza7Bok11rfgy3GkEaKpk/YSrQq7s=' 'sha256-JXxJ1myeqyP5sXv8eHm2uBwOSUzRljiHDBMspnX4XyA=' 'sha256-780dS3bZm4nWYzDRtcZ0CLWBOybm3TMijMlIymv/kt0=' 'sha256-W2uumUrToDJlcmw4VIMEqikToK5YeYJOtXzeG2GK6+E=' 'sha512-57MDmcccJXYtNnH+ZiBwzC4jb2rvgVCEokYN+L/nLlmO8rfYT/gIpW2A569iJ/3b+0UEasghjuZH/ma3wIs/EQ==' blob: https://static.cloudflareinsights.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://cloudflareinsights.com https://challenges.cloudflare.com; frame-src 'self' https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests
