# Build-time public variables for the Astro site.
# Copy to .env for local `astro dev`. In production these are set as
# build environment variables in the Cloudflare Pages dashboard.

# Cloudflare Turnstile site key (public — rendered into the contact form).
# The value below is Cloudflare's "always passes" TEST key — replace it with
# the real site key from the Turnstile dashboard for staging/production.
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
